{
  "productName": "SplitTab",
  "version": "1.0.0",
  "identifier": "com.vpradhap.splittab",
  "build": {
    "frontendDist": "../www"
  },
  "app": {
    "windows": [
      {
        "title": "SplitTab",
        "width": 420,
        "height": 820,
        "minWidth": 375,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon-32x32.png",
      "icons/icon-128x128.png",
      "icons/icon-128x128@2x.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
